# Local / generic example. For VPS production use:
#   cp .env.production.example .env
# Full guide: DEPLOY.md

APP_NAME=ProspectForge
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
ENVIRONMENT=production

# Shared-VPS ports (do NOT use 80/443 by default)
HTTP_PORT=18080
HTTPS_PORT=18443
APP_PORT=18081
POSTGRES_PORT=15432
TLS_MODE=internal
FORCE_HTTPS_COOKIES=false

DOMAIN=prospects.example.com
ACME_EMAIL=you@example.com

# Postgres (compose builds DATABASE_URL from these)
POSTGRES_USER=prospectforge
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=prospectforge

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@prospectforge.local
ADMIN_PASSWORD=changeme

# Scheduler (keep OFF until live-source quality validated)
ENABLE_SCHEDULER=false
ENABLE_NIGHTLY_INGESTION=false
RUN_MIGRATIONS=true

# Discovery
INSEE_API_KEY=
SIRENE_DELAY_SECONDS=2.1
REACHER_URL=http://reacher:8080
REACHER_ENABLED=false
HARVESTER_ENABLED=false
DECP_CACHE_PATH=/app/data/decp_cache.parquet
DECP_DAYS_BACK=120
DECP_MAX_COMPANIES=150
INGESTION_RUN_CONTACTS=false
HUNTER_API_KEY=
