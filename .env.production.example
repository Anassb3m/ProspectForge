# ═══════════════════════════════════════════════════════════════════════════
# ProspectForge — production .env for a SHARED VPS (custom ports)
#   cp .env.production.example .env && nano .env
# ═══════════════════════════════════════════════════════════════════════════

# ── Host ports (CHANGE if anything else already uses them) ─────────────────
# Public edge. Use 80/443 with TLS_MODE=acme on a dedicated VPS.
HTTP_PORT=80
HTTPS_PORT=443
# App health on host loopback only
APP_PORT=18081
CADDY_BIND=0.0.0.0

# ── TLS ────────────────────────────────────────────────────────────────────
# acme     = trusted certificate on public ports 80/443 (recommended)
# external = loopback HTTP behind an existing HTTPS reverse proxy
# internal = Caddy internal CA on custom ports for private/admin deployments
TLS_MODE=acme
CADDYFILE_PATH=./deploy/Caddyfile.acme
FORCE_HTTPS_COOKIES=true

DOMAIN=prospects.example.com
ACME_EMAIL=you@example.com
TRUSTED_HOSTS=prospects.example.com,127.0.0.1
FORWARDED_ALLOW_IPS=*

# ── Application ────────────────────────────────────────────────────────────
APP_NAME=ProspectForge
ENVIRONMENT=production
DEBUG=false
# openssl rand -hex 32
SECRET_KEY=CHANGE_ME_long_random_string

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=prospectforge
# Use alphanumerics only (avoid @ # : / in password — breaks DATABASE_URL)
# openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=prospectforge

# ── Admin (created only when users table is empty) ─────────────────────────
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Scheduler (keep OFF until live-source quality validated) ───────────────
ENABLE_SCHEDULER=false
ENABLE_NIGHTLY_INGESTION=false
RUN_MIGRATIONS=true
BACKUP_KEEP_DAYS=14

# ── Discovery ──────────────────────────────────────────────────────────────
INSEE_API_KEY=
SIRENE_DELAY_SECONDS=2.1
DECP_DAYS_BACK=120
DECP_MAX_COMPANIES=150
DECP_CACHE_PATH=/app/data/decp_cache.parquet
DECP_CACHE_HOURS=20
INGESTION_RUN_CONTACTS=false
NIGHTLY_CONTACT_BATCH_SIZE=8
CONTACT_MIN_OPPORTUNITY_SCORE=40
CONTACT_CRAWL_MAX_PAGES=12
CONTACT_CRAWL_MAX_DEPTH=2
CONTACT_CRAWL_MAX_REDIRECTS=4
CONTACT_CRAWL_REQUEST_TIMEOUT_SECONDS=10
CONTACT_CRAWL_TOTAL_TIMEOUT_SECONDS=90
CONTACT_DOMAIN_CONCURRENCY=2
CONTACT_MAX_EMAIL_CANDIDATES=6
CONTACT_REACHER_CONCURRENCY=2
CONTACT_REFRESH_DAYS=30

# ── Optional Reacher ───────────────────────────────────────────────────────
REACHER_ENABLED=false
REACHER_URL=http://reacher:8080
REACHER_IMAGE=reacherhq/backend:v0.11.7
REACHER_TIMEOUT_SECONDS=20
HARVESTER_ENABLED=false
