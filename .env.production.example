# ═══════════════════════════════════════════════════════════════════════════
# ProspectForge — production .env for a SHARED VPS (custom ports)
#   cp .env.production.example .env && nano .env
# ═══════════════════════════════════════════════════════════════════════════

# ── Host ports (CHANGE if anything else already uses them) ─────────────────
# Public edge (Caddy) — defaults avoid 80/443/8080/8443
HTTP_PORT=18080
HTTPS_PORT=18443
# App health on host loopback only
APP_PORT=18081
# Postgres on host loopback only (not 5432)
POSTGRES_PORT=15432

# ── TLS ────────────────────────────────────────────────────────────────────
# internal = self-signed HTTPS on HTTPS_PORT (recommended on shared VPS)
# off      = HTTP only on HTTP_PORT (point your existing nginx/Caddy at 127.0.0.1:APP_PORT)
# acme     = Let's Encrypt (needs free public :80 — usually not available on shared VPS)
TLS_MODE=internal
# Set true only if you access via HTTPS (TLS_MODE=internal or external TLS proxy)
FORCE_HTTPS_COOKIES=false

DOMAIN=prospects.example.com
ACME_EMAIL=you@example.com
# Optional harden: TRUSTED_HOSTS=prospects.example.com,127.0.0.1

# ── Application ────────────────────────────────────────────────────────────
APP_NAME=ProspectForge
ENVIRONMENT=production
DEBUG=false
# openssl rand -hex 32
SECRET_KEY=CHANGE_ME_long_random_string

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=prospectforge
# Use alphanumerics only (avoid @ # : / in password — breaks DATABASE_URL)
# openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=prospectforge

# ── Admin (created only when users table is empty) ─────────────────────────
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Scheduler ──────────────────────────────────────────────────────────────
ENABLE_SCHEDULER=true
ENABLE_NIGHTLY_INGESTION=true
RUN_MIGRATIONS=true

# ── Discovery ──────────────────────────────────────────────────────────────
INSEE_API_KEY=
SIRENE_DELAY_SECONDS=2.1
DECP_DAYS_BACK=120
DECP_MAX_COMPANIES=150
DECP_CACHE_PATH=/app/data/decp_cache.parquet
DECP_CACHE_HOURS=20
INGESTION_RUN_CONTACTS=false

# ── Optional Reacher ───────────────────────────────────────────────────────
REACHER_ENABLED=false
REACHER_URL=http://reacher:8080
HARVESTER_ENABLED=false
